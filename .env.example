NODE_ENV=development

# Host-side `pnpm dev` connects via this URL. The compose api service
# overrides it to `postgres:5432` for in-container traffic.
DATABASE_URL=postgresql://food_delivery:food_delivery@localhost:5432/food_delivery?schema=public
TEST_DATABASE_URL=postgresql://food_delivery:food_delivery@localhost:5433/food_delivery_test?schema=public

API_PORT=3000
WEB_PORT=5173
# Use comma-separated origins for dev devices, e.g. http://localhost:5173,http://192.168.8.121:5173
WEB_ORIGIN=http://localhost:5173
SEED_DATABASE=true

JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# OpenAPI/Swagger at /docs (default on for demo; set false in production)
ENABLE_SWAGGER=true

# Used by compose.prod.yaml overrides (demo/local prod-shape stack)
PROD_WEB_ORIGIN=http://localhost:5173
PROD_JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes-for-prod-shape
ALLOW_PROD_SEED=true
